{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "maven test",
      "type": "shell",
      "command": "mvn",
      "args": ["test"],
      "problemMatcher": ["$maven"]
    },
    {
      "label": "practice: test and unlock next",
      "type": "shell",
      "command": "mvn test && python3 tools/unlock_next_exercise.py",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$maven"]
    },
    {
      "label": "watch materials inbox",
      "type": "shell",
      "command": "python3",
      "args": ["tools/process_materials.py", "--watch"],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "unlock next exercise",
      "type": "shell",
      "command": "python3",
      "args": ["tools/unlock_next_exercise.py"],
      "problemMatcher": []
    }
  ]
}
